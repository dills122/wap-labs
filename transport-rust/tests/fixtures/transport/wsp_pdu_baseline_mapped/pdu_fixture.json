{
  "successCases": [
    {
      "name": "connect-text-header-and-capabilities",
      "decodePolicy": "strict",
      "encodePolicy": "strict",
      "encoded": [1, 1, 4, 0, 0, 8, 0, 0, 0, 16, 0, 0, 2, 16, 126, 88, 45, 83, 101, 115, 115, 105, 111, 110, 0, 105, 110, 105, 116, 0],
      "expected": {
        "kind": "connect",
        "version_major": 1,
        "version_minor": 4,
        "client_message_size": 2048,
        "server_message_size": 4096,
        "max_outstanding_requests": 2,
        "headers": [
          {
            "name": "X-Session",
            "value": "init",
            "encoding": { "kind": "text" }
          }
        ]
      }
    },
    {
      "name": "connect-reply-binary-header-and-capabilities",
      "decodePolicy": "strict-v14",
      "encodePolicy": "strict-v14",
      "encoded": [2, 1, 4, 0, 7, 0, 0, 8, 0, 0, 0, 16, 0, 0, 2, 5, 67, 49, 46, 52, 0],
      "expected": {
        "kind": "connectReply",
        "version_major": 1,
        "version_minor": 4,
        "session_id": 7,
        "client_message_size": 2048,
        "server_message_size": 4096,
        "max_outstanding_requests": 2,
        "headers": [
          {
            "name": "Encoding-Version",
            "value": "1.4",
            "encoding": { "kind": "binary", "page": 1 }
          }
        ]
      }
    },
    {
      "name": "get-content-type-binary-header",
      "decodePolicy": "strict-v14",
      "encodePolicy": "strict-v14",
      "encoded": [64, 47, 100, 101, 99, 107, 46, 119, 109, 108, 0, 17, 116, 101, 120, 116, 47, 118, 110, 100, 46, 119, 97, 112, 46, 119, 109, 108, 0],
      "expected": {
        "kind": "methodGet",
        "uri": "/deck.wml",
        "headers": [
          {
            "name": "Content-Type",
            "value": "text/vnd.wap.wml",
            "encoding": { "kind": "binary", "page": 1 }
          }
        ]
      }
    },
    {
      "name": "post-text-fallback-header-with-body",
      "decodePolicy": "strict",
      "encodePolicy": "text-fallback",
      "encoded": [96, 47, 115, 117, 98, 109, 105, 116, 0, 21, 126, 88, 45, 65, 112, 112, 45, 84, 114, 97, 99, 101, 0, 116, 114, 97, 99, 101, 45, 49, 0, 1, 2, 3],
      "expected": {
        "kind": "methodPost",
        "uri": "/submit",
        "body": [1, 2, 3],
        "headers": [
          {
            "name": "X-App-Trace",
            "value": "trace-1",
            "encoding": { "kind": "text" }
          }
        ]
      }
    },
    {
      "name": "reply-encoding-version-header-and-body",
      "decodePolicy": "strict-v14",
      "encodePolicy": "strict-v14",
      "encoded": [4, 0, 200, 5, 67, 49, 46, 52, 0, 60, 119, 109, 108, 47, 62],
      "expected": {
        "kind": "reply",
        "status_code": 200,
        "body": [60, 119, 109, 108, 47, 62],
        "headers": [
          {
            "name": "Encoding-Version",
            "value": "1.4",
            "encoding": { "kind": "binary", "page": 1 }
          }
        ]
      }
    }
  ],
  "errorCases": [
    {
      "name": "unsupported-disconnect-pdu-type",
      "decodePolicy": "strict",
      "encoded": [5],
      "expectedError": "unsupported-pdu-type",
      "unsupportedPduType": 5
    },
    {
      "name": "truncated-post-header-block",
      "decodePolicy": "strict",
      "encoded": [96, 47, 0, 10, 17, 116, 101, 120, 116, 0],
      "expectedError": "truncated"
    },
    {
      "name": "truncated-connect-header-block",
      "decodePolicy": "strict",
      "encoded": [1, 1, 4, 0, 0, 8, 0, 0, 0, 16, 0, 0, 2, 2, 126],
      "expectedError": "truncated"
    },
    {
      "name": "connect-reply-trailing-bytes",
      "decodePolicy": "strict-v14",
      "encoded": [2, 1, 4, 0, 7, 0, 0, 8, 0, 0, 0, 16, 0, 0, 2, 5, 67, 49, 46, 52, 0, 170],
      "expectedError": "trailing-bytes"
    }
  ]
}
