        "clientMessageSize": 1536,
        "serverMessageSize": 2048,
        "maxOutstandingRequests": 4
      },
      "expected": {
        "clientMessageSize": 1536,
        "serverMessageSize": 1024,
        "maxOutstandingRequests": 4
      }
    },
    {
