        "clientMessageSize": 1200,
        "maxOutstandingRequests": 2
      },
      "server": {
        "serverMessageSize": 900,
        "maxOutstandingRequests": 1
      },
      "expected": {
        "clientMessageSize": 1200,
        "serverMessageSize": 900,
        "maxOutstandingRequests": 1
      }
    }
  ],
  "boundCases": [
    {
      "mode": "connection-oriented",
      "negotiated": {
        "clientMessageSize": 1536,
        "serverMessageSize": 1024,
        "maxOutstandingRequests": 4
      },
      "inboundMessageBytes": 1024,
      "outstandingRequests": 4,
      "expected": "ok"
    },
    {
      "mode": "connection-oriented",
      "negotiated": {
        "clientMessageSize": 1536,
