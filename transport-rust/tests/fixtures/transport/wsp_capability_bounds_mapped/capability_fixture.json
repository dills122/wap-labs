      },
      "inboundMessageBytes": 1300,
      "outstandingRequests": 1,
      "expected": "MRUEXCEEDED"
    },
    {
      "mode": "connectionless",
      "negotiated": {
        "clientMessageSize": 1200,
        "serverMessageSize": 900,
        "maxOutstandingRequests": 1
      },
      "inboundMessageBytes": 700,
