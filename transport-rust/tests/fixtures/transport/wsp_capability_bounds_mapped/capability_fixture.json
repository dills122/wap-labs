        "maxOutstandingRequests": 4
      },
      "inboundMessageBytes": 1600,
      "outstandingRequests": 2,
      "expected": "MRUEXCEEDED"
    },
    {
      "mode": "connection-oriented",
      "negotiated": {
        "clientMessageSize": 1536,
        "serverMessageSize": 1024,
        "maxOutstandingRequests": 4
      },
      "inboundMessageBytes": 1000,
      "outstandingRequests": 6,
      "expected": "MOREXCEEDED"
    },
    {
      "mode": "connectionless",
      "negotiated": {
        "clientMessageSize": 1200,
        "serverMessageSize": 900,
