{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Waves Browser",
  "version": "0.1.0",
  "identifier": "com.wavenav.host",
  "build": {
    "beforeDevCommand": "pnpm --dir frontend dev",
    "beforeBuildCommand": "pnpm --dir frontend build",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Waves Browser",
        "width": 1024,
        "height": 768,
        "minWidth": 880,
        "minHeight": 640,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "publisher": "WaveNav",
    "category": "Utility",
    "shortDescription": "WAP/WML based browser 1.x",
    "longDescription": "A WAP/WML based browser 1.x for loading and navigating WML decks.",
    "copyright": "Copyright (c) 2026 WaveNav",
    "resources": [
      "resources/wbxml/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
