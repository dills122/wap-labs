{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WaveNav Host",
  "version": "0.1.0",
  "identifier": "com.wavenav.host",
  "build": {
    "beforeDevCommand": "pnpm --dir frontend dev",
    "beforeBuildCommand": "pnpm --dir frontend build",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "WaveNav Host",
        "width": 1024,
        "height": 768,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "resources": [
      "resources/wbxml/**/*"
    ],
    "icon": []
  }
}
