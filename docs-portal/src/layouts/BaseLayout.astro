---
import '../styles/global.css';
import { route } from '../lib/routes';

interface Props {
  title: string;
  description?: string;
  section?: string;
}

const {
  title,
  description = 'The living project, source, compliance, and delivery atlas for the Waves WAP/WML browser stack.',
  section = ''
} = Astro.props;

const nav = [
  ['Overview', '', 'overview'],
  ['Sources', 'sources', 'sources'],
  ['Compliance', 'compliance', 'compliance'],
  ['Planning', 'planning', 'planning'],
  ['Documents', 'docs', 'docs']
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#111814" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={route('favicon.svg')} />
    <title>{title} · WAP Labs Atlas</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="app-header">
      <a class="wordmark" href={route()} aria-label="WAP Labs Atlas home">
        <span class="wordmark-mark" aria-hidden="true">WA</span>
        <span><strong>WAP Labs</strong><small>Project atlas</small></span>
      </a>
      <nav aria-label="Primary">
        {
          nav.map(([label, href, id]) => (
            <a href={route(href)} aria-current={section === id ? 'page' : undefined}>{label}</a>
          ))
        }
      </nav>
      <a class="repo-link" href="https://github.com/dills122/wap-labs">Repository ↗</a>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="app-footer">
      <p><strong>WAP Labs Atlas</strong> is generated from the repository’s active manifests and documentation.</p>
      <p>WAP 1.2.1 · WML 1.3 · strict Class C data client</p>
    </footer>
  </body>
</html>
