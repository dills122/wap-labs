---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatusPill from '../components/StatusPill.astro';
import { clauseManifest, program, strictFamilies } from '../lib/repository';
import { route } from '../lib/routes';
---

<BaseLayout title="Compatibility contract" section="compliance">
  <header class="page-header page-shell">
    <p class="kicker">Normative target</p>
    <h1>Strict core. Explicit extensions.</h1>
    <p>
      The first compatibility target is the exact WAP-215 Class C client graph applied to the
      WAP 1.2.1 effective specification, with WML 1.3 observable behavior as the markup floor.
    </p>
  </header>
  <section class="page-shell profile-grid">
    {program.profiles.map((profile) => (
      <article class:list={['profile-card', { selected: profile.role === 'primary-strict-target' }]}>
        <div><span class="mono-id">{profile.id}</span><StatusPill status={profile.status} /></div>
        <h2>{profile.role.replaceAll('-', ' ')}</h2>
        <p>{profile.summary}</p>
      </article>
    ))}
  </section>
  <section class="page-shell split-section">
    <div class="section-intro">
      <p class="section-label">Evidence model</p>
      <h2>Requirements are extracted before they are claimed.</h2>
      <p>
        The selected profile resolves to SCR rows, then to normative clauses and fixtures. A
        work-item status is useful delivery evidence; it is not proof of standards conformance.
      </p>
    </div>
    <dl class="evidence-numbers">
      <div><dt>Selected SCR parents</dt><dd>{clauseManifest.summary.selectedParentCount}</dd></div>
      <div><dt>Required clauses</dt><dd>{clauseManifest.summary.requiredClauseCount}</dd></div>
      <div><dt>Recommended clauses</dt><dd>{clauseManifest.summary.recommendedClauseCount}</dd></div>
      <div><dt>Assessed clauses</dt><dd>{clauseManifest.summary.assessedClauseCount}</dd></div>
    </dl>
  </section>
  <section class="page-shell">
    <div class="section-heading"><div><p class="section-label">Effective surface</p><h2>{strictFamilies.length} strict families</h2></div></div>
    <div class="family-list">
      {strictFamilies.map((family) => {
        const clauseFamily = clauseManifest.families.find((entry) => entry.family === family.family);
        return (
          <article id={family.family}>
            <div class="family-name"><span class="mono-id">{family.family}</span><StatusPill status={family.targetDisposition} /></div>
            <h3>{family.title}</h3>
            <dl>
              <div><dt>Source chain</dt><dd>{family.documents.length} document{family.documents.length === 1 ? '' : 's'}</dd></div>
              <div><dt>Clause ledger</dt><dd>{clauseFamily ? `${clauseFamily.clauseCount} clauses` : family.scrExtraction?.status ?? 'pending'}</dd></div>
              <div><dt>Owners</dt><dd>{family.ownerLayers.join(', ')}</dd></div>
            </dl>
            <ul class="source-chain">
              {family.effectiveSequence.map((id) => <li><a href={route(`sources/${id}`)}>{id}</a></li>)}
            </ul>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
