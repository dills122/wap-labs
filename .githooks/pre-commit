#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pre-commit: pnpm not found. Install pnpm to run staged-file checks."
  exit 1
fi

echo "pre-commit: running lint-staged (staged files only)..."
pnpm exec lint-staged --concurrent false
echo "pre-commit: staged-file checks complete."
