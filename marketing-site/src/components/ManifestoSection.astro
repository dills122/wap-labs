    line-height: 1.02;
  }

  .manifesto-copy > p:nth-child(2) {
    max-width: 43rem;
    margin-top: var(--space-5);
    color: var(--color-ink-soft);
    font-size: 1.05rem;
    line-height: 1.65;
  }

  .outcome-list {
    display: grid;
    gap: 0.8rem;
    margin-top: var(--space-5);
    list-style: none;
  }

  .outcome-list li {
